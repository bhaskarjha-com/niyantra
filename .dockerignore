# Environment files (never commit secrets)
.env
.env.local
.env.test

# Database files
*.db
*.db-journal
*.db-wal
*.db-shm
*.db.bak

# Git
.git/
.gitignore
.gitattributes

# Build artifacts
dist/
build/
niyantra
niyantra.exe

# Private drafts (not part of the build)
draft/

# Documentation (keep README for Docker Hub)
*.md
!README.md

# Test files (not needed in Docker image)
*_test.go
coverage/
coverage.html
*.out

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Node.js (esbuild dev tools — app.js is pre-bundled)
node_modules/
package.json
package-lock.json
tsconfig.json

# TypeScript source (already bundled into static/app.js)
internal/web/src/

# GoReleaser (not needed for Docker build)
.goreleaser.yaml

# GitHub workflows
.github/

# Scripts and tools
scripts/
install.sh

# Antigravity payload dump
antigravity_payload_dump.json

# Linter config
.golangci.yml
